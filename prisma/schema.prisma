generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id               BigInt            @id @default(autoincrement())
  uuid             String            @unique
  name             String
  email            String            @unique
  address          String?
  latitude         Float?
  longitude        Float?
  password         String
  mobileNumber     String
  countryCode      String            @default("+91")
  user_type        String            @default("COMPANY")
  otp              String?
  otpExpireTime    DateTime?
  isVerified       Boolean           @default(true)
  CMPId            String?
  image            String
  lastLogin        DateTime?
  status           CompanyStatus     @default(ACTIVE)
  isDeleted        Boolean           @default(false)
  isApproved       CompmnayApproval  @default(PENDING)
  createdAt        DateTime          @default(now())
  createdById      BigInt?
  createdBy        User?             @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  competentPersons CompetentPerson[]
  projects         Project[]
  projectManagers  ProjectManager[]

  @@index([createdById], map: "Company_createdById_fkey")
}

model User {
  id               BigInt           @id @default(autoincrement())
  uuid             String           @unique
  name             String
  email            String           @unique
  password         String
  mobileNumber     String
  countryCode      String           @default("+91")
  user_type        Role
  otp              String?
  otpExpireTime    DateTime?
  status           UserStatus       @default(ACTIVE)
  isDeleted        Boolean          @default(false)
  isVerified       Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lastLogin        DateTime?
  companiesCreated Company[]        @relation("CompanyCreatedBy")
  competentPerson  CompetentPerson?
  projectManager   ProjectManager?
  tradesman        TradesMan?
  projectsManaged  Project[]        @relation("ProjectManagers")
  userMedias       UserMedia[]

  blogs Blog[]

  createdProjectInspections CompetentPersonProjectInspection[] @relation("UserCreatedProjectInspection")

  projectScaffholdTimeline ProjectScaffholdTimeline[] @relation("UserCreatedTimeline") // ✅ ADD
  notificationSetting      NotificationSetting?
}

model ProjectManager {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique
  address   String?
  latitude  Float?
  longitude Float?
  companyId BigInt?
  cmpId     String?
  uuid      String   @unique
  company   Company? @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([companyId], map: "ProjectManager_companyId_fkey")
}

model CompetentPerson {
  id        BigInt                     @id @default(autoincrement())
  userId    BigInt                     @unique
  address   String?
  companyId BigInt?
  cmpId     String?
  latitude  Float?
  longitude Float?
  uuid      String                     @unique
  company   Company?                   @relation(fields: [companyId], references: [id])
  user      User                       @relation(fields: [userId], references: [id])
  projects  CompetentPersonOnProject[]

  @@index([companyId], map: "CompetentPerson_companyId_fkey")
}

model TradesMan {
  id         BigInt  @id @default(autoincrement())
  userId     BigInt  @unique
  address    String?
  craft      String?
  craftId    Int?
  experience String?
  latitude   Float?
  longitude  Float?
  uuid       String  @unique

  user                        User                      @relation(fields: [userId], references: [id])
  craftInfo                   craft?                    @relation(fields: [craftId], references: [id])
  projects                    TradesManOnProject[]
  jobCraftsJoined             JobCraftTradesman[]
  createdProjectScaffRequests ProjectScaffholdRequest[] @relation("CreatedByTradesmanProject") // ✅ FIX
  projectContexts             TradesmanProjectContext[]
}

model Device {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  user_type   String?
  deviceToken String?
  deviceType  String?
  deviceName  String?
  appVersion  String?
  osVersion   String?
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserMedia {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt?
  mediaType MediaType
  url       String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id])
}

model craft {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  craftImage       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tradesmen        TradesMan[]
  projectJobCrafts projectJobCraft[] // ✅ ADD THIS
}

model Project {
  id                BigInt        @id @default(autoincrement())
  uuid              String        @unique
  projectName       String
  PJT               String?
  clientName        String
  clientEmail       String
  clientMobile      String
  clientCountryCode String        @default("+91")
  clientAddress     String?
  startDate         String
  endDate           String?
  latitude          Float?
  longitude         Float?
  status            ProjectStatus @default(CREATED)
  isDeleted         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  createdById BigInt?
  createdBy   Company? @relation(fields: [createdById], references: [id])

  projectManagers    User[]                             @relation("ProjectManagers")
  competentPersons   CompetentPersonOnProject[]
  TradesManRequests  ProjectScaffholdRequest[]
  tradesMen          TradesManOnProject[]
  jobCrafts          projectJobCraft[]
  projectTimelines   ProjectScaffholdTimeline[]
  projectInspections CompetentPersonProjectInspection[] // ✅ FIX
  tradesmanContexts  TradesmanProjectContext[]
  rentalCycles       RentalCycle[]
}

model CompetentPersonOnProject {
  id                BigInt          @id @default(autoincrement())
  projectid         BigInt
  competentPersonId BigInt
  project           Project         @relation(fields: [projectid], references: [id])
  competentPerson   CompetentPerson @relation(fields: [competentPersonId], references: [id])
  assignedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([projectid, competentPersonId])
  @@index([competentPersonId])
}

model TradesManOnProject {
  id          BigInt    @id @default(autoincrement())
  projectId   BigInt
  tradesManId BigInt
  project     Project   @relation(fields: [projectId], references: [id])
  tradesMan   TradesMan @relation(fields: [tradesManId], references: [id])
  assignedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([projectId, tradesManId])
  @@index([tradesManId])
}

model projectJobCraft {
  id                BigInt              @id @default(autoincrement())
  projectId         BigInt
  craftId           Int
  counts            Int
  joinedCount       Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  scaffhold         Project             @relation(fields: [projectId], references: [id])
  craft             craft               @relation(fields: [craftId], references: [id])
  jobCraftTradesmen JobCraftTradesman[]

  @@unique([projectId, craftId])
}

model JobCraftTradesman {
  id                BigInt           @id @default(autoincrement())
  jobCraftId        BigInt
  tradesmanId       BigInt
  projectJobCraftId BigInt? // ✅ ADD
  createdAt         DateTime         @default(now())
  projectJobCraft   projectJobCraft? @relation(fields: [projectJobCraftId], references: [id]) // ✅ ADD
  tradesman         TradesMan        @relation(fields: [tradesmanId], references: [id])

  @@unique([jobCraftId, tradesmanId])
}

model ProjectScaffholdRequest {
  id   BigInt @id @default(autoincrement())
  uuid String @unique

  projectId BigInt
  project   Project @relation(fields: [projectId], references: [id])

  // 🔽 FROM SCAFFHOLD
  startDate   String?
  endDate     String?
  address     String?
  latitude    Float?
  longitude   Float?
  tag         ScaffholdTags @default(UNTAGED)
  SCAFFID     String?
  description String?       @db.Text

  // 🔽 EXISTING
  craft            String?
  length           String?
  width            String?
  height           String?
  priority         Priority      @default(MEDIUM)
  expectedEndDate  String?
  REQID            String?
  notes            String?
  reajectionReason String?
  status           RequestStatus @default(PENDING)
  parentId         BigInt? // 🔥 ADD THIS

  parent                ProjectScaffholdRequest?  @relation("RequestParent", fields: [parentId], references: [id])
  children              ProjectScaffholdRequest[] @relation("RequestParent")
  // 🔥 NEW (IMPORTANT)
  isConvertedToScaffold Boolean                   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById BigInt
  createdBy   TradesMan @relation("CreatedByTradesmanProject", fields: [createdById], references: [id])

  updatesRequest            updateProjectScaffHoldRequest[]
  rentalCycles              RentalCycle[]
  projectScaffholdTimelines ProjectScaffholdTimeline[] 
  lightDuty  Boolean @default(false)

  mediumDuty Boolean @default(false)

  heavyDuty  Boolean @default(false)
}

model updateProjectScaffHoldRequest {
  id              BigInt    @id @default(autoincrement())
  requestId       BigInt
  projectId       BigInt
  length          String?
  width           String?
  height          String?
  priority        Priority?
  expectedEndDate String?
  notes           String?
  createdAt       DateTime  @default(now())

  scaffholdRequest ProjectScaffholdRequest @relation(fields: [requestId], references: [id])
}

model CompetentPersonProjectInspection {
  id        BigInt @id @default(autoincrement())
  projectId BigInt

  Project Project @relation(fields: [projectId], references: [id]) // ✅ FIX

  createdById BigInt
  createdBy   User   @relation("UserCreatedProjectInspection", fields: [createdById], references: [id]) // ✅ FIX

  shift String?
  note  String?
  Date  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TradesmanProjectContext {
  id BigInt @id @default(autoincrement())

  tradesmanId BigInt
  projectId   BigInt

  employerName String

  createdAt DateTime @default(now())

  tradesman TradesMan @relation(fields: [tradesmanId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@unique([tradesmanId, projectId])
}

model ProjectScaffholdTimeline {
  id   BigInt @id @default(autoincrement())
  uuid String @unique

  note String?

  // =========================
  // 🔥 PROJECT
  // =========================
  projectId BigInt

  scaffhold Project @relation(fields: [projectId], references: [id])

  // =========================
  // 🔥 REQUEST
  // =========================
  scaffoldRequestId BigInt

  scaffoldRequest ProjectScaffholdRequest @relation(fields: [scaffoldRequestId], references: [id])

  // =========================
  // 🔥 TIMELINE DATA
  // =========================
  timeLineStatus ScaffholdStatus

  address   String?
  latitude  Float?
  longitude Float?

  tag String?

  // =========================
  // 🔥 IMAGES
  // =========================
  image TimelineImage[] @relation("TimelineImagesMain")

  optionalImages TimelineImage[] @relation("TimelineImagesOptional")

  // =========================
  // 🔥 CREATED BY
  // =========================
  createdById BigInt

  createdBy User @relation("UserCreatedTimeline", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([scaffoldRequestId])
}

model TimelineImage {
  id     BigInt  @id @default(autoincrement())
  url    String
  status String?

  timelineId BigInt
  timeline   ProjectScaffholdTimeline @relation("TimelineImagesMain", fields: [timelineId], references: [id])

  projectTimelineId BigInt?
  projectTimeline   ProjectScaffholdTimeline? @relation("TimelineImagesOptional", fields: [projectTimelineId], references: [id])
}

model Notification {
  id                BigInt           @id @default(autoincrement())
  uuid              String           @unique
  title             String
  message           String
  type              NotificationType
  role              NotificationRole
  companyId         BigInt?
  projectId         BigInt?
  scaffoldRequestId String?
  receiverId        BigInt?
  senderId          String?
  isRead            Boolean          @default(false)
  notificationImage String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tradesmanCraft    String?
}

model NotificationSetting {
  id     BigInt @id @default(autoincrement())
  userId BigInt @unique

  // 🔐 Security Alerts
  unusualActivity Boolean @default(true)
  newDeviceLogin  Boolean @default(true)

  // 📊 Activity Notifications
  projectCreated    Boolean @default(true)
  teamMemberChanged Boolean @default(true)
  scaffoldUpdates   Boolean @default(true)

  // 📧 Master Email Toggle
  emailEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Blog {
  id          BigInt    @id @default(autoincrement())
  uuid        String    @unique
  blogTitle   String?
  category    String?
  publishDate DateTime?
  image       String?
  blogBody    String    @db.Text
  status      String?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id           BigInt   @id @default(autoincrement())
  uuid         String   @unique
  name         String
  email        String   @unique
  mobileNumber String
  countryCode  String   @default("+91")
  message      String   @db.Text
  submittedAt  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RentalCycle {
  id   BigInt @id @default(autoincrement())
  uuid String @unique

  projectId         BigInt
  scaffoldRequestId BigInt

  project         Project                 @relation(fields: [projectId], references: [id])
  scaffoldRequest ProjectScaffholdRequest @relation(fields: [scaffoldRequestId], references: [id])

  erectedAt DateTime

  taggedAt DateTime?

  // 🔥 TOTAL TIME (NEVER RESET)
  totalDays Int @default(0)

  // 🔥 MANUAL CYCLE COUNT
  cycleCount Int @default(0)

  // 🔥 RESET AFTER EACH CLEAR
  rentalDays Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scaffoldRequestId])
}

enum NotificationType {
  NEW_COMPANY_REGISTERED
  COMPANY_AWAITING_APPROVAL
  NEW_SCAFFOLD_CREATED
  SCAFFOLD_STATUS_UPDATE
  SCAFFOLD_COMPLETED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  TRADESMAN_REMOVED
  INSPECTION_UPDATE
  SCAFFHOLD_REQUEST
  MODIFICATION_REQUEST
  MODIFICATION_ACCEPTED
  MODIFICATION_REJECTED
  TIMELINE_UPDATE
  SCAFFOLD_ASSIGNED
  TRADESMAN_JOINED_PROJECT
  DAILY_INSPECTION_REMINDER
  PROJECT_ASSIGNED
  PROJECT_MODIFIED
}

enum NotificationRole {
  SUPER_ADMIN
  COMPANY
  PROJECT_MANAGER
  COMPETENT_PERSON
  TRADESMAN
}

enum RequestStatus {
  APPROVED
  REJECTED
  PENDING
  PRE_ERECTED
  ERECTED
  ACTIVE
  SUSPENDED
  DISMANTLED
}

enum ProjectStatus {
  CREATED
  ONGOING
  COMPLETED
  CANCELLED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
  PENDING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum CompmnayApproval {
  APPROVED
  REJECTED
  PENDING
}

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  COMPETENT_PERSON
  TRADESMAN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MediaType {
  COMPANY_IMAGE
  PHOTO_IMAGE
  ID_PROOF_IMAGE
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ScaffholdStatus {
  UNTAGED
  ACTIVE
  PRE_ERECTED
  ERECTED
  SUSPENDED
  DISMANTLED
  COMPLETED
}

enum ScaffholdTags {
  UNTAGED
  GREEN
  RED
  YELLOW
}
