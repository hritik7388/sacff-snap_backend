generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id               BigInt            @id @default(autoincrement())
  uuid             String            @unique
  name             String
  email            String            @unique
  address          String?
  latitude         Float?
  longitude        Float?
  password         String
  mobileNumber     String
  countryCode      String            @default("+91")
  user_type        String            @default("COMPANY")
  otp              String?
  otpExpireTime    DateTime?
  isVerified       Boolean           @default(true)
  CMPId            String?
  image            String
  lastLogin        DateTime?
  status           CompanyStatus     @default(ACTIVE)
  isDeleted        Boolean           @default(false)
  isApproved       CompmnayApproval  @default(PENDING)
  createdAt        DateTime          @default(now())
  createdById      BigInt?
  createdBy        User?             @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  competentPersons CompetentPerson[]
  projects         Project[]
  projectManagers  ProjectManager[]

  @@index([createdById], map: "Company_createdById_fkey")
}

model User {
  id                        BigInt                             @id @default(autoincrement())
  uuid                      String                             @unique
  name                      String
  email                     String                             @unique
  password                  String
  mobileNumber              String
  countryCode               String                             @default("+91")
  user_type                 Role
  otp                       String?
  otpExpireTime             DateTime?
  status                    UserStatus                         @default(ACTIVE)
  isDeleted                 Boolean                            @default(false)
  isVerified                Boolean                            @default(true)
  createdAt                 DateTime                           @default(now())
  updatedAt                 DateTime                           @updatedAt
  lastLogin                 DateTime?
  blogs                     Blog[]
  companiesCreated          Company[]                          @relation("CompanyCreatedBy")
  competentPerson           CompetentPerson?
  createdProjectInspections CompetentPersonProjectInspection[] @relation("UserCreatedProjectInspection")
  notificationSetting       NotificationSetting?
  projectManager            ProjectManager?
  projectScaffholdTimeline  ProjectScaffholdTimeline[]         @relation("UserCreatedTimeline")
  tradesman                 TradesMan?
  userMedias                UserMedia[]
  projectsManaged           Project[]                          @relation("ProjectManagers")
}

model ProjectManager {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique
  address   String?
  latitude  Float?
  longitude Float?
  companyId BigInt?
  cmpId     String?
  uuid      String   @unique
  company   Company? @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([companyId], map: "ProjectManager_companyId_fkey")
}

model CompetentPerson {
  id        BigInt                     @id @default(autoincrement())
  userId    BigInt                     @unique
  address   String?
  companyId BigInt?
  cmpId     String?
  latitude  Float?
  longitude Float?
  uuid      String                     @unique
  company   Company?                   @relation(fields: [companyId], references: [id])
  user      User                       @relation(fields: [userId], references: [id])
  projects  CompetentPersonOnProject[]

  @@index([companyId], map: "CompetentPerson_companyId_fkey")
}

model TradesMan {
  id                          BigInt                    @id @default(autoincrement())
  userId                      BigInt                    @unique
  address                     String?
  craft                       String?
  craftId                     Int?
  experience                  String?
  latitude                    Float?
  longitude                   Float?
  uuid                        String                    @unique
  jobCraftsJoined             JobCraftTradesman[]
  createdProjectScaffRequests ProjectScaffholdRequest[] @relation("CreatedByTradesmanProject")
  craftInfo                   craft?                    @relation(fields: [craftId], references: [id])
  user                        User                      @relation(fields: [userId], references: [id])
  projects                    TradesManOnProject[]
  projectContexts             TradesmanProjectContext[]

  @@index([craftId], map: "TradesMan_craftId_fkey")
}

model Device {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  user_type   String?
  deviceToken String?
  deviceType  String?
  deviceName  String?
  appVersion  String?
  osVersion   String?
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserMedia {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt?
  mediaType MediaType
  url       String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "UserMedia_userId_fkey")
}

model craft {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  craftImage       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tradesmen        TradesMan[]
  projectJobCrafts projectJobCraft[]
}

model Project {
  id                 BigInt                             @id @default(autoincrement())
  uuid               String                             @unique
  projectName        String
  clientName         String
  clientEmail        String
  clientMobile       String
  clientCountryCode  String                             @default("+91")
  clientAddress      String?
  startDate          String
  endDate            String?
  latitude           Float?
  longitude          Float?
  status             ProjectStatus                      @default(CREATED)
  isDeleted          Boolean                            @default(false)
  createdAt          DateTime                           @default(now())
  updatedAt          DateTime                           @updatedAt
  createdById        BigInt?
  PJT                String?
  competentPersons   CompetentPersonOnProject[]
  projectInspections CompetentPersonProjectInspection[]
  createdBy          Company?                           @relation(fields: [createdById], references: [id])
  TradesManRequests  ProjectScaffholdRequest[]
  projectTimelines   ProjectScaffholdTimeline[]
  rentalCycles       RentalCycle[]
  tradesMen          TradesManOnProject[]
  tradesmanContexts  TradesmanProjectContext[]
  jobCrafts          projectJobCraft[]
  projectManagers    User[]                             @relation("ProjectManagers")

  @@index([createdById], map: "Project_createdById_fkey")
}

model CompetentPersonOnProject {
  id                BigInt          @id @default(autoincrement())
  projectid         BigInt
  competentPersonId BigInt
  assignedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  competentPerson   CompetentPerson @relation(fields: [competentPersonId], references: [id])
  project           Project         @relation(fields: [projectid], references: [id])

  @@unique([projectid, competentPersonId])
  @@index([competentPersonId])
}

model TradesManOnProject {
  id          BigInt    @id @default(autoincrement())
  projectId   BigInt
  tradesManId BigInt
  assignedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id])
  tradesMan   TradesMan @relation(fields: [tradesManId], references: [id])

  @@unique([projectId, tradesManId])
  @@index([tradesManId])
}

model projectJobCraft {
  id                BigInt              @id @default(autoincrement())
  projectId         BigInt
  craftId           Int
  counts            Int
  joinedCount       Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  jobCraftTradesmen JobCraftTradesman[]
  craft             craft               @relation(fields: [craftId], references: [id])
  scaffhold         Project             @relation(fields: [projectId], references: [id])

  @@unique([projectId, craftId])
  @@index([craftId], map: "projectJobCraft_craftId_fkey")
}

model JobCraftTradesman {
  id                BigInt           @id @default(autoincrement())
  jobCraftId        BigInt
  tradesmanId       BigInt
  createdAt         DateTime         @default(now())
  projectJobCraftId BigInt?
  projectJobCraft   projectJobCraft? @relation(fields: [projectJobCraftId], references: [id])
  tradesman         TradesMan        @relation(fields: [tradesmanId], references: [id])

  @@unique([jobCraftId, tradesmanId])
  @@index([projectJobCraftId], map: "JobCraftTradesman_projectJobCraftId_fkey")
  @@index([tradesmanId], map: "JobCraftTradesman_tradesmanId_fkey")
}

model ProjectScaffholdRequest {
  id                        BigInt                             @id @default(autoincrement())
  uuid                      String                             @unique
  projectId                 BigInt
  craft                     String?
  length                    String?
  width                     String?
  height                    String?
  priority                  String?
  expectedEndDate           String?
  REQID                     String?
  notes                     String?
  reajectionReason          String?
  status                    RequestStatus                      @default(PENDING)
  createdAt                 DateTime                           @default(now())
  updatedAt                 DateTime                           @updatedAt
  createdById               BigInt
  SCAFFID                   String?
  address                   String?
  description               String?                            @db.Text
  endDate                   String?
  isConvertedToScaffold     Boolean                            @default(false)
  latitude                  Float?
  longitude                 Float?
  startDate                 String?
  tag                       ScaffholdTags                      @default(UNTAGED)
  parentId                  BigInt?
  heavyDuty                 Boolean                            @default(false)
  lightDuty                 Boolean                            @default(false)
  mediumDuty                Boolean                            @default(false)
  fallProtection            Boolean                            @default(false)
  handRail                  Boolean                            @default(false)
  ladder                    Boolean                            @default(false)
  midRail                   Boolean                            @default(false)
  note                      String?                            @db.Text
  other                     String?                            @db.Text
  platform                  Boolean                            @default(false)
  toeBoard                  Boolean                            @default(false)
  projectInspections        CompetentPersonProjectInspection[]
  createdBy                 TradesMan                          @relation("CreatedByTradesmanProject", fields: [createdById], references: [id])
  parent                    ProjectScaffholdRequest?           @relation("RequestParent", fields: [parentId], references: [id])
  children                  ProjectScaffholdRequest[]          @relation("RequestParent")
  project                   Project                            @relation(fields: [projectId], references: [id])
  projectScaffholdTimelines ProjectScaffholdTimeline[]
  rentalCycles              RentalCycle[]
  updatesRequest            updateProjectScaffHoldRequest[]

  @@index([createdById], map: "ProjectScaffholdRequest_createdById_fkey")
  @@index([parentId], map: "ProjectScaffholdRequest_parentId_fkey")
  @@index([projectId], map: "ProjectScaffholdRequest_projectId_fkey")
}

model updateProjectScaffHoldRequest {
  id               BigInt                  @id @default(autoincrement())
  requestId        BigInt
  projectId        BigInt
  length           String?
  width            String?
  height           String?
  priority         Priority?
  expectedEndDate  String?
  notes            String?
  createdAt        DateTime                @default(now())
  scaffholdRequest ProjectScaffholdRequest @relation(fields: [requestId], references: [id])

  @@index([requestId], map: "updateProjectScaffHoldRequest_requestId_fkey")
}

model CompetentPersonProjectInspection {
  id                BigInt                   @id @default(autoincrement())
  projectId         BigInt
  createdById       BigInt
  shift             String?
  note              String?
  Date              String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  scaffoldRequestId BigInt?
  createdBy         User                     @relation("UserCreatedProjectInspection", fields: [createdById], references: [id])
  Project           Project                  @relation(fields: [projectId], references: [id])
  scaffoldRequest   ProjectScaffholdRequest? @relation(fields: [scaffoldRequestId], references: [id])

  @@index([createdById], map: "CompetentPersonProjectInspection_createdById_fkey")
  @@index([projectId], map: "CompetentPersonProjectInspection_projectId_fkey")
  @@index([scaffoldRequestId], map: "CompetentPersonProjectInspection_scaffoldRequestId_fkey")
}

model TradesmanProjectContext {
  id           BigInt    @id @default(autoincrement())
  tradesmanId  BigInt
  projectId    BigInt
  employerName String
  createdAt    DateTime  @default(now())
  project      Project   @relation(fields: [projectId], references: [id])
  tradesman    TradesMan @relation(fields: [tradesmanId], references: [id])

  @@unique([tradesmanId, projectId])
  @@index([projectId], map: "TradesmanProjectContext_projectId_fkey")
}

model ProjectScaffholdTimeline {
  id                BigInt                  @id @default(autoincrement())
  uuid              String                  @unique
  note              String?
  projectId         BigInt
  timeLineStatus    ScaffholdStatus
  address           String?
  latitude          Float?
  longitude         Float?
  tag               String?
  createdById       BigInt
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  scaffoldRequestId BigInt
  createdBy         User                    @relation("UserCreatedTimeline", fields: [createdById], references: [id])
  scaffhold         Project                 @relation(fields: [projectId], references: [id])
  scaffoldRequest   ProjectScaffholdRequest @relation(fields: [scaffoldRequestId], references: [id])
  optionalImages    TimelineImage[]         @relation("TimelineImagesOptional")
  image             TimelineImage[]         @relation("TimelineImagesMain")

  @@index([projectId])
  @@index([scaffoldRequestId])
  @@index([createdById], map: "ProjectScaffholdTimeline_createdById_fkey")
}

model TimelineImage {
  id                BigInt                    @id @default(autoincrement())
  url               String
  status            String?
  timelineId        BigInt
  projectTimelineId BigInt?
  projectTimeline   ProjectScaffholdTimeline? @relation("TimelineImagesOptional", fields: [projectTimelineId], references: [id])
  timeline          ProjectScaffholdTimeline  @relation("TimelineImagesMain", fields: [timelineId], references: [id])

  @@index([projectTimelineId], map: "TimelineImage_projectTimelineId_fkey")
  @@index([timelineId], map: "TimelineImage_timelineId_fkey")
}

model Notification {
  id                BigInt           @id @default(autoincrement())
  uuid              String           @unique
  title             String
  message           String
  type              NotificationType
  role              NotificationRole
  companyId         BigInt?
  projectId         BigInt?
  scaffoldRequestId String?
  receiverId        BigInt?
  senderId          String?
  isRead            Boolean          @default(false)
  notificationImage String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tradesmanCraft    String?
}

model NotificationSetting {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt   @unique
  unusualActivity   Boolean  @default(true)
  newDeviceLogin    Boolean  @default(true)
  projectCreated    Boolean  @default(true)
  teamMemberChanged Boolean  @default(true)
  scaffoldUpdates   Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model Blog {
  id          BigInt    @id @default(autoincrement())
  uuid        String    @unique
  blogTitle   String?
  category    String?
  publishDate DateTime?
  image       String?
  blogBody    String    @db.Text
  status      String?   @default("CREATED")
  createdById BigInt
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [createdById], references: [id])

  @@index([createdById], map: "Blog_createdById_fkey")
}

model ContactSubmission {
  id           BigInt   @id @default(autoincrement())
  uuid         String   @unique
  name         String
  email        String
  mobileNumber String
  countryCode  String   @default("+91")
  message      String   @db.Text
  submittedAt  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RentalCycle {
  id                BigInt                  @id @default(autoincrement())
  uuid              String                  @unique
  projectId         BigInt
  erectedAt         DateTime
  taggedAt          DateTime?
  totalDays         Int                     @default(0)
  cycleCount        Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  scaffoldRequestId BigInt
  rentalDays        Int                     @default(0)
  project           Project                 @relation(fields: [projectId], references: [id])
  scaffoldRequest   ProjectScaffholdRequest @relation(fields: [scaffoldRequestId], references: [id])

  @@index([scaffoldRequestId])
  @@index([projectId])
}

enum NotificationType {
  NEW_COMPANY_REGISTERED
  COMPANY_AWAITING_APPROVAL
  NEW_SCAFFOLD_CREATED
  SCAFFOLD_STATUS_UPDATE
  SCAFFOLD_COMPLETED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  TRADESMAN_REMOVED
  INSPECTION_UPDATE
  SCAFFHOLD_REQUEST
  MODIFICATION_REQUEST
  MODIFICATION_ACCEPTED
  MODIFICATION_REJECTED
  TIMELINE_UPDATE
  SCAFFOLD_ASSIGNED
  TRADESMAN_JOINED_PROJECT
  DAILY_INSPECTION_REMINDER
  PROJECT_ASSIGNED
  PROJECT_MODIFIED
  NEW_TEAM_MEMBER_CREATED
}

enum NotificationRole {
  SUPER_ADMIN
  COMPANY
  PROJECT_MANAGER
  COMPETENT_PERSON
  TRADESMAN
}

enum RequestStatus {
  APPROVED
  REJECTED
  PENDING
  PRE_ERECTED
  ERECTED
  ACTIVE
  SUSPENDED
  DISMANTLED
}

enum ProjectStatus {
  CREATED
  ONGOING
  COMPLETED
  CANCELLED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
  PENDING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum CompmnayApproval {
  APPROVED
  REJECTED
  PENDING
}

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  COMPETENT_PERSON
  TRADESMAN
}

enum MediaType {
  COMPANY_IMAGE
  PHOTO_IMAGE
  ID_PROOF_IMAGE
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ScaffholdStatus {
  UNTAGED
  ACTIVE
  PRE_ERECTED
  ERECTED
  SUSPENDED
  DISMANTLED
  COMPLETED
}

enum ScaffholdTags {
  UNTAGED
  GREEN
  RED
  YELLOW
}
