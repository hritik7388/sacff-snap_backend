generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id               BigInt            @id @default(autoincrement())
  uuid             String            @unique
  name             String
  email            String            @unique
  address          String?
  latitude         Float?
  longitude        Float?
  password         String
  mobileNumber     String
  countryCode      String            @default("+91")
  user_type        String            @default("COMPANY")
  CMPId            String?
  image            String
  lastLogin        DateTime?
  status           CompanyStatus     @default(ACTIVE)
  isDeleted        Boolean           @default(false)
  isApproved       CompmnayApproval  @default(PENDING)
  createdAt        DateTime          @default(now())
  createdById      BigInt?
  createdBy        User?             @relation("CompanyCreatedBy", fields: [createdById], references: [id])
  competentPersons CompetentPerson[]
  projects         Project[]
  projectManagers  ProjectManager[]
  scaffholds       Scaffhold[]

  @@index([createdById], map: "Company_createdById_fkey")
}

model User {
  id                 BigInt                      @id @default(autoincrement())
  uuid               String                      @unique
  name               String
  email              String                      @unique
  password           String
  mobileNumber       String
  countryCode        String                      @default("+91")
  user_type          Role
  otp                String?
  otpExpireTime      DateTime?
  status             UserStatus                  @default(ACTIVE)
  isDeleted          Boolean                     @default(false)
  isVerified         Boolean                     @default(true)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  lastLogin          DateTime?
  companiesCreated   Company[]                   @relation("CompanyCreatedBy")
  competentPerson    CompetentPerson?
  projectManager     ProjectManager?
  tradesman          TradesMan?
  projectsJoined     Project[]                   @relation("ProjectManager")
  userMedias         UserMedia[]
  scaffholdsCreated  Scaffhold[]                 @relation("UserCreatedScaffhold")
  createdInspections CompetentPersonInspection[] @relation("UserCreatedInspection")
  scaffholdTimeline  ScaffholdTimeline[]         @relation("UserCreatedTimeline")
}

model ProjectManager {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique
  address   String?
  latitude  Float?
  longitude Float?
  companyId BigInt?
  cmpId     String?
  uuid      String   @unique
  company   Company? @relation(fields: [companyId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([companyId], map: "ProjectManager_companyId_fkey")
}

model CompetentPerson {
  id         BigInt                       @id @default(autoincrement())
  userId     BigInt                       @unique
  address    String?
  companyId  BigInt?
  cmpId      String?
  latitude   Float?
  longitude  Float?
  uuid       String                       @unique
  company    Company?                     @relation(fields: [companyId], references: [id])
  user       User                         @relation(fields: [userId], references: [id])
  scaffholds CompetentPersonOnScaffhold[]

  @@index([companyId], map: "CompetentPerson_companyId_fkey")
}

model TradesMan {
  id                   BigInt                 @id @default(autoincrement())
  userId               BigInt                 @unique
  address              String?
  craft                String?
  craftId              Int?
  experience           String?
  latitude             Float?
  longitude            Float?
  uuid                 String                 @unique
  user                 User                   @relation(fields: [userId], references: [id])
  craftInfo            craft?                 @relation(fields: [craftId], references: [id])
  scaffholds           TradesManOnScaffhold[]
  jobCraftsJoined      JobCraftTradesman[]
  createdScaffRequests ScaffholdRequest[]     @relation("CreatedByTradesman")
}

model Device {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt
  user_type   String?
  deviceToken String?
  deviceType  String?
  deviceName  String?
  appVersion  String?
  osVersion   String?
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserMedia {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt?
  mediaType MediaType
  url       String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User?     @relation(fields: [userId], references: [id])
}

model craft {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  craftImage String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  jobCrafts  JobCraft[]
  tradesmen  TradesMan[]
}

model Project {
  id                BigInt        @id @default(autoincrement())
  uuid              String        @unique
  projectName       String
  clientName        String
  clientEmail       String
  clientMobile      String
  clientCountryCode String        @default("+91")
  clientAddress     String?
  startDate         String
  endDate           String?
  latitude          Float?
  longitude         Float?
  status            ProjectStatus @default(CREATED)
  isDeleted         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdById       BigInt?
  createdBy         Company?      @relation(fields: [createdById], references: [id])
  projectManagerId  BigInt?
  projectManager    User?         @relation("ProjectManager", fields: [projectManagerId], references: [id])
  scaffholds        Scaffhold[]

  @@index([createdById], map: "Project_createdById_fkey")
}

model Scaffhold {
  id                         BigInt                       @id @default(autoincrement())
  uuid                       String                       @unique
  startDate                  String
  endDate                    String?
  address                    String?
  latitude                   Float?
  longitude                  Float?
  priority                   Priority                     @default(MEDIUM)
  tag                        ScaffholdTags                @default(UNTAGED)
  descreption                String?
  SCAFFID                    String?
  status                     ScaffholdStatus              @default(ACTIVE)
  isDeleted                  Boolean                      @default(false)
  isJobLinkCreated           Boolean                      @default(false)
  projectId                  BigInt?
  projectName                String?
  project                    Project?                     @relation(fields: [projectId], references: [id])
  companyId                  BigInt?
  company                    Company?                     @relation(fields: [companyId], references: [id])
  createdById                BigInt?
  createdBy                  User?                        @relation("UserCreatedScaffhold", fields: [createdById], references: [id])
  competentPersons           CompetentPersonOnScaffhold[]
  tradesMen                  TradesManOnScaffhold[]
  jobCrafts                  JobCraft[]
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  TradesManRequests          ScaffholdRequest[]           @relation("ScaffholdToRequest")
  competentPersonInspections CompetentPersonInspection[]
  scaffholdTimeline          ScaffholdTimeline[]

  @@index([projectId], map: "Scaffhold_projectId_fkey")
  @@index([companyId], map: "Scaffhold_companyId_fkey")
  @@index([createdById], map: "Scaffhold_createdById_fkey")
}

model CompetentPersonOnScaffhold {
  id                BigInt          @id @default(autoincrement())
  scaffholdId       BigInt
  competentPersonId BigInt
  scaffhold         Scaffhold       @relation(fields: [scaffholdId], references: [id])
  competentPerson   CompetentPerson @relation(fields: [competentPersonId], references: [id])
  assignedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([scaffholdId, competentPersonId])
  @@index([competentPersonId])
}

model TradesManOnScaffhold {
  id          BigInt    @id @default(autoincrement())
  scaffholdId BigInt
  tradesManId BigInt
  scaffhold   Scaffhold @relation(fields: [scaffholdId], references: [id])
  tradesMan   TradesMan @relation(fields: [tradesManId], references: [id])
  assignedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([scaffholdId, tradesManId])
  @@index([tradesManId])
}

model JobCraft {
  id                BigInt              @id @default(autoincrement())
  scaffholdId       BigInt
  craftId           Int
  counts            Int
  joinedCount       Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  scaffhold         Scaffhold           @relation(fields: [scaffholdId], references: [id])
  craft             craft               @relation(fields: [craftId], references: [id])
  jobCraftTradesmen JobCraftTradesman[]

  @@unique([scaffholdId, craftId])
}

model JobCraftTradesman {
  id          BigInt    @id @default(autoincrement())
  jobCraftId  BigInt
  tradesmanId BigInt
  createdAt   DateTime  @default(now())
  jobCraft    JobCraft  @relation(fields: [jobCraftId], references: [id])
  tradesman   TradesMan @relation(fields: [tradesmanId], references: [id])

  @@unique([jobCraftId, tradesmanId])
}

model ScaffholdRequest {
  id               BigInt                   @id @default(autoincrement())
  uuid             String                   @unique
  scaffholdId      BigInt
  scaffhold        Scaffhold                @relation("ScaffholdToRequest", fields: [scaffholdId], references: [id])
  craft            String?
  length           String?
  width            String?
  height           String?
  priority         Priority                 @default(MEDIUM)
  expectedEndDate  String?
  REQID            String?
  notes            String?
  reajectionReason String?
  reason           String?
  status           RequestStatus            @default(PENDING)
  parentId         BigInt?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  createdById      BigInt
  createdBy        TradesMan                @relation("CreatedByTradesman", fields: [createdById], references: [id])
  updatesRequest   updateScaffHoldRequest[]
}

model updateScaffHoldRequest {
  id              BigInt    @id @default(autoincrement())
  requestId       BigInt
  scaffholdId     BigInt
  length          String?
  width           String?
  height          String?
  priority        Priority?
  expectedEndDate String?
  notes           String?
  createdAt       DateTime  @default(now())

  scaffholdRequest ScaffholdRequest @relation(fields: [requestId], references: [id])
}

model CompetentPersonInspection {
  id          BigInt    @id @default(autoincrement())
  scaffholdId BigInt
  scaffhold   Scaffhold @relation(fields: [scaffholdId], references: [id])

  createdById BigInt
  createdBy   User   @relation("UserCreatedInspection", fields: [createdById], references: [id])

  shift     String?
  note      String?
  Date      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScaffholdTimeline {
  id             BigInt          @id @default(autoincrement())
  uuid           String          @unique
  note           String?
  scaffholdId    BigInt
  timeLineStatus ScaffholdStatus
  address        String?
  latitude       Float?
  longitude      Float?
  tag            String?
  image          TimelineImage[]
  scaffhold      Scaffhold       @relation(fields: [scaffholdId], references: [id])
  createdById    BigInt
  createdBy      User            @relation("UserCreatedTimeline", fields: [createdById], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TimelineImage {
  id         BigInt            @id @default(autoincrement())
  url        String
  status     String?
  timelineId BigInt
  timeline   ScaffholdTimeline @relation(fields: [timelineId], references: [id])
}

model Notification {
  id         BigInt           @id @default(autoincrement())
  uuid       String           @unique
  title      String
  message    String
  type       NotificationType
  role       NotificationRole
  companyId  BigInt?
  projectId  BigInt?
  scaffoldId BigInt?
  receiverId BigInt?
  senderId   String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

enum NotificationType {
  NEW_COMPANY_REGISTERED
  COMPANY_AWAITING_APPROVAL
  NEW_SCAFFOLD_CREATED
  SCAFFOLD_STATUS_UPDATE
  SCAFFOLD_COMPLETED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  TRADESMAN_REMOVED
  INSPECTION_UPDATE
  MODIFICATION_REQUEST
  TIMELINE_UPDATE
  SCAFFOLD_OVERDUE
}

enum NotificationRole {
  SUPER_ADMIN
  COMPANY
  PROJECT_MANAGER
  COMPETENT_PERSON
  TRADESMAN
}

enum RequestStatus {
  APPROVED
  REJECTED
  PENDING
}

enum ProjectStatus {
  CREATED
  ONGOING
  COMPLETED
  CANCELLED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
  PENDING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum CompmnayApproval {
  APPROVED
  REJECTED
  PENDING
}

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  COMPETENT_PERSON
  TRADESMAN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MediaType {
  COMPANY_IMAGE
  PHOTO_IMAGE
  ID_PROOF_IMAGE
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ScaffholdStatus {
  UNTAGED
  ACTIVE
  PRE_ERECTED
  ERECTED
  SUSPENDED
  DISMANTLED
  COMPLETED
}

enum ScaffholdTags {
  UNTAGED
  GREEN
  RED
  YELLOW
}
